# ──────────────────────────────────────────────────────────────────────────────
# Local development overrides — copy to .env (never commit .env)
# In AWS, all values are injected automatically via CloudFormation references.
# ──────────────────────────────────────────────────────────────────────────────

# DynamoDB (injected by CloudFormation in AWS)
TABLE_APPOINTMENTS=Appointments

# SNS (injected by CloudFormation in AWS)
SNS_APPOINTMENTS_ARN=arn:aws:sns:us-east-1:111111111111:appointmentTopic

# EventBridge bus name (injected by CloudFormation in AWS)
EB_BUS_NAME=appointments-bus

# RDS — Peru
RDS_PE_HOST=localhost
RDS_PE_PORT=3306
RDS_PE_DATABASE=appointmentspe

# RDS — Chile
RDS_CL_HOST=localhost
RDS_CL_PORT=3306
RDS_CL_DATABASE=appointmentscl

# RDS — shared credentials
RDS_USER=admin
# Use RDS_PASSWORD for local dev. In AWS, the password is read from SSM (RDS_PASSWORD_SSM).
RDS_PASSWORD=change-me-locally
RDS_PASSWORD_SSM=/appointments/rds/password

# SQS — injected by CloudFormation in AWS
SQS_PE_URL=https://sqs.us-east-1.amazonaws.com/111111111111/appointments-pe
SQS_PE_ARN=arn:aws:sqs:us-east-1:111111111111:appointments-pe
SQS_CL_URL=https://sqs.us-east-1.amazonaws.com/111111111111/appointments-cl
SQS_CL_ARN=arn:aws:sqs:us-east-1:111111111111:appointments-cl
CONFIRMATIONS_SQS_URL=https://sqs.us-east-1.amazonaws.com/111111111111/appointments-confirmaciones
CONFIRMATIONS_SQS_ARN=arn:aws:sqs:us-east-1:111111111111:appointments-confirmaciones
