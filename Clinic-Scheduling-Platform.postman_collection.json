{
  "info": {
    "_postman_id": "clinic-scheduling-platform-collection",
    "name": "Clinic Scheduling Platform",
    "description": "Postman collection for testing the Clinic Scheduling Platform API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Create Appointment - PE",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"insuredId\": \"12345\",\n  \"scheduleId\": 10,\n  \"countryISO\": \"PE\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments"
              ]
            },
            "description": "Creates a medical appointment request for Peru."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response status is successful', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202]);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response body contains expected information', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('object');",
                  "    pm.expect(JSON.stringify(json).toLowerCase()).to.match(/pending|received|appointment|success|message/);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Appointment - CL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"insuredId\": \"67890\",\n  \"scheduleId\": 20,\n  \"countryISO\": \"CL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments"
              ]
            },
            "description": "Creates a medical appointment request for Chile."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response status is successful', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202]);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Appointment - Invalid Payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"insuredId\": \"\",\n  \"scheduleId\": null,\n  \"countryISO\": \"XX\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments"
              ]
            },
            "description": "Negative test case to validate API error handling."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid payload returns client error', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://your-api-id.execute-api.us-east-1.amazonaws.com/dev",
      "type": "string"
    }
  ]
}